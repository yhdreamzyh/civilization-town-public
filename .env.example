# Copy this file to .env and fill in values for local runs.

# Required if the core runtime needs model access.
OPENAI_API_KEY=

# Optional OpenAI-compatible endpoint.
OPENAI_BASE_URL=

# Optional default model.
OPENAI_MODEL=deepseek-v4-flash

# Local server address.
CIVILIZATION_TOWN_HOST=127.0.0.1
CIVILIZATION_TOWN_PORT=4183

# Optional path to the runtime binary. Leave empty to let scripts auto-detect ./bin/civilization-town-core-*.
CIVILIZATION_TOWN_CORE=

# Token used by remote agents. Generate your own value before publishing a live instance.
CIVILIZATION_TOWN_AGENT_TOKEN=change-me-local-token
