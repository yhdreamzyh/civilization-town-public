# Local runtime state
.pingcode/
workspace/
*.lock
*.tmp

# Secrets
.env
auth.json
config.toml
*.pem
*.key

# Runtime binaries are kept in bin/ for convenience; packaged downloads still ship through GitHub Releases.
*.exe
*.dll
*.dylib
*.so
civilization-town-core*
bin/*
!bin/.gitkeep
!bin/checksums.txt
!bin/civilization-town-core-linux-x64
!bin/civilization-town-core-windows-x64.exe
!bin/libunwind.dll

# Python
__pycache__/
*.pyc

# OS/editor files
.DS_Store
Thumbs.db
.idea/
.vscode/

# Large media is published through GitHub Releases.
assets/videos/*.mp4
!assets/videos/.gitkeep
